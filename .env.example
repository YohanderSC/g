# ── BASE DE DATOS ─────────────────────────────────
#
# Con psycopg3 (OPCIÓN A - Windows recomendado):
#DATABASE_URL=postgresql+psycopg://postgres:password@localhost:8080/ruleta_db
DATABASE_URL=postgresql+psycopg://postgres:Conejo.30@localhost:8080/ruleta_db
#DB_HOST=localhost
#DB_PORT=8080
#DB_NAME=ruleta_db
#DB_USER=postgres
#DB_PASSWORD=Conejo.30
#SECRET_KEY=clave_secreta_segura_cambiar_en_produccion
#ALGORITHM=HS256
#ACCESS_TOKEN_EXPIRE_MINUTES=1440
#DEBUG=True
#
# Con psycopg2 (OPCIÓN B - Linux/Mac):
# DATABASE_URL=postgresql://postgres:password@localhost:5432/ruleta_db

# ── SERVIDOR ──────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=True
APP_RELOAD=True

# ── CORREO SMTP ───────────────────────────────────
MAIL_USERNAME=tu_correo@gmail.com
MAIL_PASSWORD=xxxx_xxxx_xxxx_xxxx
MAIL_FROM=no-reply@tuempresa.com
MAIL_FROM_NAME=Ruleta de Premios
MAIL_PORT=587
MAIL_SERVER=smtp.gmail.com
MAIL_TLS=True
MAIL_SSL=False
MAIL_LOTE_SIZE=500

# ── SEGURIDAD ─────────────────────────────────────
# Generar con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=cambia_esta_clave_por_una_muy_segura
TOKEN_LENGTH=32

# ── PAGINACIÓN ────────────────────────────────────
PAGE_SIZE=20
